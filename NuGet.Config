<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="GitHub" value="https://nuget.pkg.github.com/crgolden/index.json" />
  </packageSources>
  <!-- Pins "Shared" to the private GitHub Packages feed only, so a same-named/same-versioned public
       package on nuget.org (e.g. dependency confusion, or an auth hiccup causing silent fallback)
       can never be substituted for it. Everything else still resolves from nuget.org as normal.
       Credentials intentionally live outside this file: local dev uses %AppData%\NuGet\NuGet.Config,
       CI supplies a NuGetPackageSourceCredentials_GitHub env var — see Directory or Functions repo's
       NuGet.Config/workflow for the reference implementation. -->
  <packageSourceMapping>
    <packageSource key="GitHub">
      <package pattern="Shared" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
